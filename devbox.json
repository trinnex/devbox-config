{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.2/.schema/devbox.schema.json",
  "packages": [
    "nano@latest",
    "git@latest",
    "starship@latest",
    "bat@latest",
    "eza@latest",
    "direnv@latest",
    "glow@latest",
    "jq@latest",
    "yq-go@latest",
    "grype@latest",
    "gawk@latest"
  ],
  "env": {
    "DEVBOX_GLOBAL_PREFIX": "$HOME/.local/share/devbox/global/default/.devbox/nix/profile/default",
    "DEVBOX_GLOBAL_ROOT":   "$HOME/.local/share/devbox/global/current"
  },
  "shell": {
    "init_hook": [
      "test -z \"$BASH_VERSION\" || source \"$DEVBOX_GLOBAL_ROOT/init.bash\"",
      "test -z \"$FISH_VERSION\" || source \"$DEVBOX_GLOBAL_ROOT/init.fish\""
    ],
    "scripts": {
      "test": [
        "echo \"Error: no test specified\" && exit 1"
      ]
    }
  }
}
